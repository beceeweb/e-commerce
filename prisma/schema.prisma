// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/database/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ROLE {
  ADMIN
  WORKER
  CLIENT
}

/// Compte utilisateur (client, worker ou admin)
model User {
  id                String             @id
  name              String
  email             String
  emailVerified     Boolean            @default(false)
  role              ROLE               @default(CLIENT)
  image             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  sessions          Session[]
  accounts          Account[]
  orders            Order[]
  addresses         Address[]
  couponRedemptions CouponRedemption[]
  cart              Cart?

  twoFactorEnabled Boolean?    @default(false)
  twoFactors       TwoFactor[]

  @@unique([email])
  @@map("user")
}

/// Session active d'un utilisateur connecté
model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

/// Compte OAuth lié à un utilisateur (Google, GitHub, etc.)
model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

/// Token temporaire pour vérification d'email ou réinitialisation de mot de passe
model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

/// Configuration 2FA d'un utilisateur (secret TOTP + codes de secours)
model TwoFactor {
  id          String  @id
  secret      String
  backupCodes String
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  verified    Boolean @default(false)

  @@index([secret])
  @@index([userId])
  @@map("twoFactor")
}

/// Catégorie de produits (ex: vêtements, chaussures)
model Category {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  type     String
  products Product[]
}

/// Produit du catalogue (entité principale sans prix ni stock — voir ProductVariant)
model Product {
  id               String             @id @default(cuid())
  name             String
  brand            String?
  description      String?
  slug             String             @unique
  imageUrl         String?
  isActive         Boolean            @default(true)
  categoryId       String?
  category         Category?          @relation(fields: [categoryId], references: [id])
  promotionProduct PromotionProduct[]
  productVariants  ProductVariant[]
  orderItems       OrderItem[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([categoryId])
  @@index([isActive])
}

/// Déclinaison d'un produit avec prix, stock et SKU (ex: taille M rouge)
model ProductVariant {
  id                   String                @id @default(cuid())
  productId            String
  product              Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  name                 String
  imageUrl             String
  slug                 String
  sku                  String?               @unique
  price                Int
  currency             String                @default("eur")
  stockOnHand          Int                   @default(0)
  stockReserved        Int                   @default(0)
  isActive             Boolean               @default(true)
  productVariantImages ProductVariantImage[]
  orderItems           OrderItem[]
  inventoryMovements   InventoryMovement[]
  cartItems            CartItem[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@unique([productId, slug])
  @@index([name])
  @@index([productId])
}

/// Image associée à une variante de produit (ordonnée par position)
model ProductVariantImage {
  id               String         @id @default(cuid())
  url              String
  productVariantId String
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  position         Int?           @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([productVariantId, position])
  @@index([productVariantId])
}

/// Adresse de livraison ou de facturation d'un utilisateur
model Address {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName         String
  lastName          String
  line1             String
  line2             String?
  city              String
  postalCode        String
  country           String
  phone             String?
  isDefaultShipping Boolean  @default(false)
  isDefaultBilling  Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
}

enum ORDER_STATUS {
  PENDING
  PAID
  FULFILLED
  SHIPPED
  DELIVERED
  FAILED
  CANCELLED
  REFUNDED
  EXPIRED
  RETURNED
}

/// Commande passée par un client (montants en centimes)
model Order {
  id                 String               @id @default(cuid())
  email              String?
  status             ORDER_STATUS         @default(PENDING)
  shippingAddress    Json
  billingAddress     Json
  shippingAmount     Int
  taxAmount          Int
  discountAmount     Int
  subtotalAmount     Int
  totalAmount        Int
  currency           String               @default("eur")
  userId             String?
  user               User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  idempotencyKey     String               @unique
  items              OrderItem[]
  payments           Payment[]
  couponRedemptions  CouponRedemption[]
  inventoryMovements InventoryMovement[]
  shipments          Shipment[]
  orderStatusHistory OrderStatusHistory[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  expiresAt          DateTime?

  @@index([userId])
  @@index([email])
  @@index([createdAt])
}

/// Historique des changements de statut d'une commande
model OrderStatusHistory {
  id         String        @id @default(cuid())
  orderId    String
  order      Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus ORDER_STATUS?
  toStatus   ORDER_STATUS
  reason     String?
  createdAt  DateTime      @default(now())
}

/// Ligne d'une commande (snapshot du produit/variant au moment de l'achat)
model OrderItem {
  id              String          @id @default(cuid())
  quantity        Int
  productImageUrl String?
  unitPrice       Int
  discountAmount  Int             @default(0)
  finalUnitPrice  Int
  lineTotalAmount Int //finalPrice * quantity
  productName     String
  variantName     String
  orderId         String
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String?
  product         Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variantId       String?
  variant         ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

enum PROMOTION_TYPE {
  PERCENTAGE
  FIXED
}

/// Promotion automatique appliquée à des produits (% ou montant fixe)
model Promotion {
  id               String             @id @default(cuid())
  type             PROMOTION_TYPE
  value            Int
  currency         String?            @default("eur")
  startsAt         DateTime?
  endsAt           DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  promotionProduct PromotionProduct[]
}

/// Table de liaison entre une promotion et les produits concernés
model PromotionProduct {
  productId   String
  promotionId String
  product     Product   @relation(fields: [productId], references: [id])
  promotion   Promotion @relation(fields: [promotionId], references: [id])

  @@id([productId, promotionId])
}

/// Code promo saisi manuellement par le client lors du checkout
model Coupon {
  id               String             @id @default(cuid())
  value            Int
  currency         String             @default("eur")
  type             PROMOTION_TYPE
  code             String             @unique
  usageCount       Int                @default(0)
  maxUses          Int?
  maxUsesPerUser   Int?
  isActive         Boolean            @default(true)
  startsAt         DateTime
  expiresAt        DateTime
  couponRedemption CouponRedemption[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([isActive])
}

/// Utilisation d'un coupon sur une commande (évite les doubles usages)
model CouponRedemption {
  id             String   @id @default(cuid())
  orderId        String
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  couponId       String
  coupon         Coupon   @relation(fields: [couponId], references: [id], onDelete: Restrict)
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  code           String
  discountAmount Int
  usedAt         DateTime @default(now())

  @@unique([orderId, couponId])
}

enum PAYMENT_STATUS {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

/// Tentative de paiement pour une commande (Stripe, etc.)
model Payment {
  id                String         @id @default(cuid())
  orderId           String
  order             Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider          String
  providerSessionId String?        @unique
  providerPaymentId String?        @unique
  status            PAYMENT_STATUS @default(PENDING)
  amount            Int
  refunds           Refund[]
  currency          String         @default("eur")
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([orderId])
  @@index([status])
}

enum REFUND_STATUS {
  PENDING
  SUCCEEDED
  FAILED
}

/// Remboursement partiel ou total d'un paiement
model Refund {
  id               String        @id @default(cuid())
  paymentId        String
  payment          Payment       @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  providerRefundId String?       @unique
  amount           Int
  currency         String        @default("eur")
  reason           String?
  status           REFUND_STATUS @default(PENDING)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([paymentId])
}

/// Événement webhook reçu d'un provider (idempotence — évite le double traitement)
model WebhookEvent {
  id         String   @id @default(cuid())
  provider   String
  eventId    String   @unique
  type       String
  receivedAt DateTime @default(now())
}

enum INVENTORY_MOVEMENT_TYPE {
  RESTOCK
  RESERVE
  RELEASE
  SALE
  RETURN
  ADJUSTMENT
  DAMAGED
  LOST
}

/// Mouvement de stock sur une variante (réservation, vente, retour, ajustement…)
model InventoryMovement {
  id        String                  @id @default(cuid())
  variantId String
  variant   ProductVariant          @relation(fields: [variantId], references: [id], onDelete: Cascade)
  orderId   String?
  order     Order?                  @relation(fields: [orderId], references: [id], onDelete: SetNull)
  type      INVENTORY_MOVEMENT_TYPE
  quantity  Int
  reason    String?
  createdAt DateTime                @default(now())
}

enum SHIPMENT_STATUS {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  FAILED
  RETURNED
}

enum SHIPPING_METHOD {
  COLLISSIMO
  FAST_DELIVERY
}

/// Expédition physique d'une commande (numéro de suivi, transporteur)
model Shipment {
  id                 String          @id @default(cuid())
  orderId            String
  order              Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider           String?
  externalShipmentId String?
  carrier            String?
  trackingNumber     String?
  trackingUrl        String?
  status             SHIPMENT_STATUS @default(PENDING)
  shippingCost       Int             @default(0)
  shippedAt          DateTime?
  shippingMethod     SHIPPING_METHOD
  deliveredAt        DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([orderId])
}

/// Panier d'achat (utilisateur connecté ou anonyme via anonymousId)
model Cart {
  id          String     @id @default(cuid())
  anonymousId String?    @unique
  userId      String?    @unique
  user        User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       CartItem[]
  expiresAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

/// Article dans un panier (variant + quantité)
model CartItem {
  id        String         @id @default(cuid())
  cartId    String
  cart      Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity  Int
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([cartId, variantId])
}
